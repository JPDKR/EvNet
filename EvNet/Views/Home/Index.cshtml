@{
    ViewBag.Title = "Inicio";
}

<div class="d-flex align-items-center gap-2 page-title mt-3">
    <i class="bi bi-house-door-fill fs-4"></i>
    <h2 class="mb-0 fs-4">
        Bienvenido
        @if (Session["UserID"] != null)
        {
            <span class="text-muted fw-normal fs-5 ms-1">@Session["UserName"].ToString()</span>
        }
    </h2>
</div>

<div class="row g-4 mt-1">
    <div class="col-md-4">
        <div class="card dashboard-card h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="p-2 bg-primary bg-opacity-10 rounded-3">
                        <i class="bi bi-people-fill fs-3 text-primary"></i>
                    </div>
                </div>
                <h5 class="card-title fw-semibold">Clientes</h5>
                <p class="card-text text-muted small">Administrá el registro de clientes: altas, modificaciones y bajas.</p>
                <a href="@Url.Action("Index", "Cliente")" class="btn btn-primary btn-sm mt-2">
                    <i class="bi bi-arrow-right me-1"></i> Ver Clientes
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card dashboard-card h-100 opacity-75">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="p-2 bg-info bg-opacity-10 rounded-3">
                        <i class="bi bi-receipt fs-3 text-info"></i>
                    </div>
                    <span class="badge bg-secondary">Próximamente</span>
                </div>
                <h5 class="card-title fw-semibold">Facturas</h5>
                <p class="card-text text-muted small">Registrá y gestioná las facturas del sistema.</p>
                <button class="btn btn-outline-info btn-sm mt-2" disabled>
                    <i class="bi bi-clock me-1"></i> No disponible
                </button>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card dashboard-card h-100 opacity-75">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="p-2 bg-secondary bg-opacity-10 rounded-3">
                        <i class="bi bi-gear-fill fs-3 text-secondary"></i>
                    </div>
                    <span class="badge bg-secondary">Próximamente</span>
                </div>
                <h5 class="card-title fw-semibold">Sistema</h5>
                <p class="card-text text-muted small">Configuración y opciones generales del sistema.</p>
                <button class="btn btn-outline-secondary btn-sm mt-2" disabled>
                    <i class="bi bi-clock me-1"></i> No disponible
                </button>
            </div>
        </div>
    </div>
</div>
