@model EvNet.Data.Clientes

@{
    ViewBag.Title = "Iniciar Sesión";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="login-wrapper">
    <div class="login-card">
        <div class="card shadow">
            <div class="card-header bg-dark text-white text-center py-4">
                <div class="mb-2">
                    <i class="bi bi-lightning-charge-fill text-warning" style="font-size: 2.5rem;"></i>
                </div>
                <h4 class="mb-0 fw-bold">EvNet</h4>
                <small class="text-white-50">Sistema de Gestión</small>
            </div>
            <div class="card-body p-4">
                @if (ViewBag.ErrorLog == true)
                {
                    <div class="alert alert-danger alert-dismissible" role="alert">
                        <i class="bi bi-exclamation-circle-fill me-2"></i>
                        Credenciales incorrectas. Intentá de nuevo.
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                    </div>
                }

                @using (Html.BeginForm("Login", "Home", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <div class="mb-3">
                        @Html.LabelFor(a => a.Email, new { @class = "form-label" })
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            @Html.TextBoxFor(a => a.Email, new { @class = "form-control", placeholder = "correo@ejemplo.com" })
                        </div>
                        @Html.ValidationMessageFor(a => a.Email, "", new { @class = "text-danger small" })
                    </div>

                    <div class="mb-4">
                        @Html.LabelFor(a => a.Password, new { @class = "form-label" })
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            @Html.PasswordFor(a => a.Password, new { @class = "form-control", placeholder = "Contraseña" })
                        </div>
                        @Html.ValidationMessageFor(a => a.Password, "", new { @class = "text-danger small" })
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Ingresar
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
