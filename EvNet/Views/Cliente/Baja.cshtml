@model EvNet.Data.Clientes

@{
    ViewBag.Title = "Eliminar Cliente";
}

<div class="page-header">
    <h2><span class="glyphicon glyphicon-trash"></span> Eliminar Cliente</h2>
</div>

<div class="row">
    <div class="col-md-5">
        @if (ViewBag.ErrorLog == true)
        {
            <div class="alert alert-danger alert-dismissible" role="alert">
                <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                <span class="glyphicon glyphicon-exclamation-sign"></span> Ocurrió un error al eliminar el cliente.
            </div>
        }

        <div class="alert alert-warning">
            <span class="glyphicon glyphicon-warning-sign"></span>
            <strong>Atención:</strong> Esta acción eliminará permanentemente al cliente del sistema.
        </div>

        @using (Html.BeginForm("Baja", "Cliente", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="panel panel-danger">
                <div class="panel-heading"><strong>Confirmar Eliminación</strong></div>
                <div class="panel-body">
                    <div class="form-group">
                        @Html.LabelFor(a => a.Id, "ID del Cliente a eliminar", new { @class = "control-label" })
                        @Html.TextBoxFor(a => a.Id, new { @class = "form-control" })
                        @Html.ValidationMessageFor(a => a.Id, "", new { @class = "text-danger" })
                    </div>
                </div>
                <div class="panel-footer">
                    <button type="submit" class="btn btn-danger">
                        <span class="glyphicon glyphicon-trash"></span> Confirmar Eliminación
                    </button>
                    @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-default" })
                </div>
            </div>
        }
    </div>
</div>
