@model IEnumerable<EvNet.Data.Clientes>

@{
    ViewBag.Title = "Clientes";
}

<div class="d-flex align-items-center justify-content-between page-title mt-3">
    <div class="d-flex align-items-center gap-2">
        <i class="bi bi-people-fill fs-4"></i>
        <h2 class="mb-0 fs-4">Clientes</h2>
    </div>
    <a href="@Url.Action("Alta", "Cliente")" class="btn btn-success btn-sm">
        <i class="bi bi-person-plus me-1"></i> Nuevo Cliente
    </a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th style="width:60px;">#</th>
                    <th>Nombre</th>
                    <th>Apellido</th>
                    <th>Email</th>
                    <th>Domicilio</th>
                    <th class="text-center" style="width:100px;">Estado</th>
                    <th class="text-center" style="width:140px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                            No hay clientes registrados.
                        </td>
                    </tr>
                }
                @foreach (var cli in Model)
                {
                    <tr>
                        <td class="text-muted small">@cli.Id</td>
                        <td class="fw-medium">@cli.Nombre</td>
                        <td>@cli.Apellido</td>
                        <td class="text-muted small">@cli.Email</td>
                        <td class="text-muted small">@cli.Domicilio</td>
                        <td class="text-center">
                            @if (cli.Habilitado)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle">
                                    <i class="bi bi-check-circle-fill me-1"></i>Activo
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">
                                    <i class="bi bi-dash-circle me-1"></i>Inactivo
                                </span>
                            }
                        </td>
                        <td class="text-center">
                            <a href="@Url.Action("Modificacion", "Cliente", new { id = cli.Id })" class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a href="@Url.Action("Baja", "Cliente", new { id = cli.Id })" class="btn btn-sm btn-outline-danger ms-1">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
