@model IEnumerable<EvNet.Data.Clientes>

@{
    ViewBag.Title = "Clientes";
}

<div class="page-header">
    <h2><span class="glyphicon glyphicon-user"></span> Clientes</h2>
</div>

<div class="row" style="margin-bottom: 15px;">
    <div class="col-xs-12">
        @Html.ActionLink("+ Nuevo Cliente", "Alta", null, new { @class = "btn btn-success" })
    </div>
</div>

<div class="panel panel-default">
    <div class="panel-body" style="padding: 0;">
        <table class="table table-striped table-bordered table-hover" style="margin-bottom: 0;">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Apellido</th>
                    <th>Email</th>
                    <th>Domicilio</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cli in Model)
                {
                    <tr>
                        <td>@cli.Id</td>
                        <td>@cli.Nombre</td>
                        <td>@cli.Apellido</td>
                        <td>@cli.Email</td>
                        <td>@cli.Domicilio</td>
                        <td class="text-center">
                            @if (cli.Habilitado)
                            {
                                <span class="label label-success">Activo</span>
                            }
                            else
                            {
                                <span class="label label-default">Inactivo</span>
                            }
                        </td>
                        <td class="text-center">
                            @Html.ActionLink("Editar", "Modificacion", new { id = cli.Id }, new { @class = "btn btn-xs btn-warning" })
                            @Html.ActionLink("Eliminar", "Baja", new { id = cli.Id }, new { @class = "btn btn-xs btn-danger" })
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
