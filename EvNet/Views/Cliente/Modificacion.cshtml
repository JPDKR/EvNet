@model EvNet.Data.Clientes

@{
    ViewBag.Title = "Editar Cliente";
}

<div class="page-header">
    <h2><span class="glyphicon glyphicon-pencil"></span> Editar Cliente</h2>
</div>

<div class="row">
    <div class="col-md-6">
        @if (ViewBag.ErrorLog == true)
        {
            <div class="alert alert-danger alert-dismissible" role="alert">
                <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                <span class="glyphicon glyphicon-exclamation-sign"></span> Ocurrió un error al guardar los cambios.
            </div>
        }

        @using (Html.BeginForm("Modificacion", "Cliente", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="panel panel-default">
                <div class="panel-heading"><strong>Datos del Cliente</strong></div>
                <div class="panel-body">
                    <div class="form-group">
                        @Html.LabelFor(a => a.Id, new { @class = "control-label" })
                        @Html.TextBoxFor(a => Model.Id, new { @class = "form-control", @readonly = "readonly" })
                        @Html.ValidationMessageFor(a => a.Id, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(a => a.Nombre, new { @class = "control-label" })
                        @Html.TextBoxFor(a => Model.Nombre, new { @class = "form-control" })
                        @Html.ValidationMessageFor(a => a.Nombre, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(a => a.Apellido, new { @class = "control-label" })
                        @Html.TextBoxFor(a => Model.Apellido, new { @class = "form-control" })
                        @Html.ValidationMessageFor(a => a.Apellido, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(a => a.Domicilio, new { @class = "control-label" })
                        @Html.TextBoxFor(a => Model.Domicilio, new { @class = "form-control" })
                        @Html.ValidationMessageFor(a => a.Domicilio, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(a => a.Email, new { @class = "control-label" })
                        @Html.TextBoxFor(a => Model.Email, new { @class = "form-control" })
                        @Html.ValidationMessageFor(a => a.Email, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(a => a.Password, new { @class = "control-label" })
                        @Html.PasswordFor(a => Model.Password, new { @class = "form-control", placeholder = "Nueva contraseña (dejar vacío para no cambiar)" })
                        @Html.ValidationMessageFor(a => a.Password, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(a => a.Ciudades, "Ciudad", new { @class = "control-label" })
                        @Html.DropDownListFor(a => Model.IdCiudad, new SelectList(ViewBag.Ciudades, "Id", "Nombre"), "-- Seleccioná una ciudad --", new { @class = "form-control" })
                        @Html.ValidationMessageFor(a => a.Ciudades, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        <div class="checkbox">
                            <label>
                                @Html.CheckBoxFor(a => Model.Habilitado) Habilitado
                            </label>
                        </div>
                    </div>
                </div>
                <div class="panel-footer">
                    <button type="submit" class="btn btn-warning">
                        <span class="glyphicon glyphicon-floppy-disk"></span> Guardar Cambios
                    </button>
                    @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-default" })
                </div>
            </div>
        }
    </div>
</div>
