@page "/clientes/baja/{Id:int}"
@rendermode InteractiveServer
@attribute [Authorize]
@inject ClienteAccess ClienteAccess
@inject NavigationManager Nav

<PageTitle>Eliminar Cliente - EvNet</PageTitle>

<div class="d-flex align-items-center gap-2 page-title mt-3">
    <i class="bi bi-trash-fill fs-4 text-danger"></i>
    <h2 class="mb-0 fs-4">Eliminar Cliente</h2>
</div>

<div class="row">
    <div class="col-md-5 col-lg-4">
        @if (errorEliminar)
        {
            <div class="alert alert-danger" role="alert">
                <i class="bi bi-exclamation-circle-fill me-2"></i> Ocurrió un error al eliminar el cliente.
                <button type="button" class="btn-close float-end" @onclick="() => errorEliminar = false" aria-label="Cerrar"></button>
            </div>
        }

        @if (cliente is null)
        {
            <div class="alert alert-warning">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> Cliente no encontrado.
            </div>
            <a href="/clientes" class="btn btn-outline-secondary">Volver</a>
        }
        else
        {
            <div class="alert alert-warning mb-4">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <strong>Atención:</strong> Esta acción eliminará permanentemente al cliente del sistema.
            </div>

            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <i class="bi bi-person-x me-2"></i><strong>Confirmar Eliminación</strong>
                </div>
                <div class="card-body p-4">
                    <p><strong>ID:</strong> @cliente.Id</p>
                    <p><strong>Nombre:</strong> @cliente.Nombre @cliente.Apellido</p>
                    <p class="mb-0"><strong>Email:</strong> @cliente.Email</p>
                </div>
                <div class="card-footer d-flex gap-2">
                    <button class="btn btn-danger" @onclick="Eliminar">
                        <i class="bi bi-trash me-1"></i> Confirmar Eliminación
                    </button>
                    <a href="/clientes" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }

    private Clientes? cliente;
    private bool errorEliminar = false;

    protected override void OnParametersSet()
    {
        cliente = ClienteAccess.Obtener(Id);
    }

    private void Eliminar()
    {
        try
        {
            ClienteAccess.Eliminar(Id);
            Nav.NavigateTo("/clientes");
        }
        catch
        {
            errorEliminar = true;
        }
    }
}
