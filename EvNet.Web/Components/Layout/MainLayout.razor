@inherits LayoutComponentBase

<nav class="navbar navbar-expand-md navbar-dark bg-dark fixed-top">
    <div class="container">
        <a class="navbar-brand" href="/inicio">
            <i class="bi bi-lightning-charge-fill text-warning"></i> EvNet
        </a>
        <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbar-main"
                aria-controls="navbar-main" aria-expanded="false" aria-label="Menú">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbar-main">
            <AuthorizeView>
                <Authorized>
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item dropdown">
                            <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown"
                               role="button" aria-expanded="false">
                                <i class="bi bi-people"></i> Clientes
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" href="/clientes">
                                        <i class="bi bi-list-ul me-2"></i>Lista de Clientes
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item" href="/clientes/alta">
                                        <i class="bi bi-person-plus me-2"></i>Nuevo Cliente
                                    </a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <span class="nav-link disabled">
                                <i class="bi bi-receipt"></i> Facturas
                                <span class="badge bg-secondary ms-1" style="font-size:0.65rem;">Próximo</span>
                            </span>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item me-1">
                            <button class="btn btn-link nav-link text-white border-0 px-2"
                                    title="Cambiar tema" aria-label="Cambiar tema"
                                    onclick="toggleTheme()">
                                <i class="bi bi-moon-fill theme-icon-dark"></i>
                                <i class="bi bi-sun-fill theme-icon-light"></i>
                            </button>
                        </li>
                        <li class="nav-item dropdown">
                            <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown"
                               role="button" aria-expanded="false">
                                <i class="bi bi-person-circle"></i> @context.User.Identity?.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item text-danger" href="/cerrar-sesion">
                                        <i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>
</nav>

<div class="container body-content">
    @Body
    <footer class="text-muted text-center">
        <p>&copy; @DateTime.Now.Year EvNet &mdash; Sistema de Gestión</p>
    </footer>
</div>
